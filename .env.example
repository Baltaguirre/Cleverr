# Copy to .env.local and fill in. .env.local is gitignored.
# `vercel dev` loads these automatically.

# Your Anthropic API key (starts with sk-ant-...). Get it at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Shared passphrase that gates the /api/generate endpoint. Pick anything;
# you'll enter the same value in the app's AI settings.
APP_PASSPHRASE=
